# ─── Required ────────────────────────────────────────────────────
# Your Anthropic API key — used by the module generator to call Claude
ANTHROPIC_API_KEY=sk-ant-...

# ─── Module Secrets (optional, per-module) ───────────────────────
# Set these for modules that need API keys.
# Convention: FWUBBO_SECRET_<KEYNAME_UPPERCASE>
# The module's manifest.requires lists the key names.

# Example: weather module
# FWUBBO_SECRET_OPENWEATHERMAP_KEY=your-key-here

# Example: finance module
# FWUBBO_SECRET_FINNHUB_TOKEN=your-token-here

# Example: news module
# FWUBBO_SECRET_NEWSAPI_KEY=your-key-here

# Example: modules that use Claude for analysis
# FWUBBO_SECRET_ANTHROPIC_KEY=sk-ant-...
