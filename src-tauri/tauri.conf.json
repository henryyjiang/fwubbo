{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Fwubbo",
  "version": "0.1.0",
  "identifier": "com.fwubbo.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Fwubbo",
        "label": "main",
        "width": 1280,
        "height": 800,
        "center": true,
        "resizable": true
      }
    ],
    "trayIcon": {
      "id": "fwubbo-tray",
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "tooltip": "Fwubbo Dashboard"
    }
  },
  "bundle": {
    "active": true, 
    "targets": ["app", "dmg"], 
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "infoPlist": "Info.plist"
    }
  }
}